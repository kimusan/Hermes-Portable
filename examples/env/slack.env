# Slack gateway example for Hermes Portable.
# Copy the values you need into data/.env; do not commit real tokens or IDs.
#
# Token locations in https://api.slack.com/apps:
# - SLACK_BOT_TOKEN: OAuth & Permissions -> Bot User OAuth Token. Must start xoxb-.
#   Do NOT use the app Verification Token or Signing Secret here.
# - SLACK_APP_TOKEN: Basic Information -> App-Level Tokens. Must start xapp-
#   and include the connections:write scope.
# - SLACK_ALLOWED_USERS: your Slack profile -> More -> Copy member ID.
#   Usually starts with U or W. Without this (or an explicit allow-all flag),
#   Hermes will authenticate to Slack but deny everyone.

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_ALLOWED_USERS=U0123456789

# Optional, intentionally open access instead of SLACK_ALLOWED_USERS.
# Use with care.
# SLACK_ALLOW_ALL_USERS=true

# Optional: default target for cron jobs and proactive sends.
# Set this from Slack with /sethome after the gateway is running, or paste a channel ID here.
# SLACK_HOME_CHANNEL=<channel-id>
# SLACK_HOME_CHANNEL_NAME=general

# Optional: allow normal chat without @mention in specific channels.
# SLACK_FREE_RESPONSE_CHANNELS=<channel-id>
# SLACK_REQUIRE_MENTION=true
