# Discord gateway example for Hermes Portable.
# Copy the values you need into data/.env; do not commit real tokens or IDs.

DISCORD_BOT_TOKEN=<discord-bot-token>
DISCORD_ALLOWED_USERS=<discord-user-id>

# Optional: default target for cron jobs and proactive sends.
# Set this from Discord with /sethome after the gateway is running, or paste a channel ID here.
# DISCORD_HOME_CHANNEL=<channel-id>
# DISCORD_HOME_CHANNEL_NAME=Home

# Optional: allow normal chat without @mention in specific channels.
# DISCORD_FREE_RESPONSE_CHANNELS=<channel-id>
# DISCORD_REQUIRE_MENTION=true
