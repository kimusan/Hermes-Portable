# Telegram gateway example for Hermes Portable.
# Copy the values you need into data/.env; do not commit real tokens or IDs.

TELEGRAM_BOT_TOKEN=<bot-token-from-botfather>
TELEGRAM_ALLOWED_USERS=<numeric-telegram-user-id>

# Optional: default target for cron jobs and proactive sends.
# Set this from Telegram with /sethome after the gateway is running, or paste a chat ID here.
# TELEGRAM_HOME_CHANNEL=<chat-id>
# TELEGRAM_HOME_CHANNEL_NAME=Home

# Optional for groups: require @mentions unless a chat is explicitly configured otherwise.
# TELEGRAM_REQUIRE_MENTION=true
# TELEGRAM_ALLOWED_CHATS=<chat-id-or-group-id>
