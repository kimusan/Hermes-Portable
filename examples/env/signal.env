# Signal gateway example for Hermes Portable.
# Copy the values you need into data/.env; do not commit real phone numbers if this file is tracked.

SIGNAL_HTTP_URL=http://127.0.0.1:8080
SIGNAL_ACCOUNT=<your-e164-signal-number>
SIGNAL_ALLOWED_USERS=<allowed-e164-number-or-signal-uuid>

# Optional: default target for cron jobs and proactive sends.
# SIGNAL_HOME_CHANNEL=<e164-number-or-recipient-id>
# SIGNAL_HOME_CHANNEL_NAME=Home

# Optional: groups are ignored by default unless allowed.
# SIGNAL_GROUP_ALLOWED_USERS=<signal-group-id>
